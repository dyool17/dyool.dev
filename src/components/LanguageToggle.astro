---
import { LOCALES, LOCALE_META, t, getLocaleFromPath } from '../i18n';

interface Props {
  // Optional: an explicit URL in each other locale. When provided, the
  // switch uses this instead of computing the localized path from the
  // current URL. Useful for blog posts whose counterpart is a specific
  // translated slug.
  alternates?: Partial<Record<(typeof LOCALES)[number], string>>;
}

const { alternates = {} } = Astro.props;
const currentLocale = getLocaleFromPath(Astro.url.pathname);
const strings = t(currentLocale);

// Build the destination URL for each language:
//   1. Prefer the explicit alternate (set by the page route, e.g. for
//      translated blog posts).
//   2. Otherwise, treat this toggle as a regular link and let the page route
//      handle the rest by emitting the path with the locale prefix swapped.
// The actual fallback to `/<locale>/blog/` for missing translations happens
// server-side in the page route; here we just provide a sensible default.
const currentPath = Astro.url.pathname;
const stripAndLocalize = (loc: (typeof LOCALES)[number]) => {
  const stripped = currentPath.replace(/^\/es(?=\/|$)/, '');
  if (loc === 'en') return stripped || '/';
  if (stripped === '/' || stripped === '') return '/es/';
  return `/es${stripped}`;
};
---

<div class="lang-switch" role="group" aria-label={strings.languageSwitch.label}>
  {
    LOCALES.map((loc) => {
      const meta = LOCALE_META[loc];
      const href = alternates[loc] ?? stripAndLocalize(loc);
      const isCurrent = loc === currentLocale;
      return (
        <a
          href={href}
          hreflang={meta.htmlLang}
          class:list={['lang-option', { active: isCurrent }]}
          aria-current={isCurrent ? 'true' : undefined}
          aria-label={isCurrent
            ? `${meta.label} (${strings.languageSwitch.label})`
            : strings.languageSwitch.switchTo.replace('{lang}', meta.label)}
          lang={meta.htmlLang}
          data-lang={loc}
        >
          {meta.short}
        </a>
      );
    })
  }
</div>

<style>
  .lang-switch {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--bg-elevated);
    padding: 2px;
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
  }

  .lang-option {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.85rem;
    height: 1.45rem;
    padding: 0 0.55rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--text-soft);
    text-decoration: none;
    transition:
      color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
    -webkit-tap-highlight-color: transparent;
  }

  .lang-option + .lang-option {
    margin-left: 1px;
  }

  .lang-option.active {
    background: var(--text);
    color: var(--text-on-inverse);
    box-shadow: var(--shadow-sm);
  }

  .lang-option:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  @media (hover: hover) and (pointer: fine) {
    .lang-switch:hover {
      border-color: var(--border-strong);
    }
    .lang-option:not(.active):hover {
      color: var(--text);
      background: var(--bg-elevated-2);
    }
    .lang-option:active {
      transform: scale(0.97);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lang-option {
      transition: none;
    }
  }
</style>

<script is:inline>
  // Persist the user's explicit language choice on click. The <a> elements
  // handle the actual navigation — this script never redirects and never
  // reads from storage during page parse, so it can't cause a flash of
  // unstyled content on the destination page.
  (() => {
    const STORAGE_KEY = 'preferred-lang';
    document.querySelectorAll('.lang-switch .lang-option').forEach((el) => {
      el.addEventListener('click', () => {
        const lang = el.getAttribute('data-lang');
        if (lang === 'en' || lang === 'es') {
          try {
            localStorage.setItem(STORAGE_KEY, lang);
          } catch {
            // Ignore quota / private-mode errors — the toggle still navigates.
          }
        }
      });
    });
  })();
</script>
