---
import { t, getLocaleFromPath, localizePath, otherLocale } from '../i18n';
import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  // URL of the current page in the OTHER language. Passed in by BaseLayout
  // from the page route's precomputed `alternateUrl` (e.g. a translated
  // blog post's counterpart, or the locale's blog index as a fallback).
  alternateUrl?: string | null;
}

const { alternateUrl = null } = Astro.props as Props;

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const strings = t(locale);

// Navigation items: hrefs are locale-aware, labels come from the i18n table.
const NAV = [
  { href: localizePath('/', locale), label: strings.nav.home },
  { href: localizePath('/about/', locale), label: strings.nav.about },
  { href: localizePath('/projects/', locale), label: strings.nav.projects },
  { href: localizePath('/blog/', locale), label: strings.nav.blog },
  { href: localizePath('/now/', locale), label: strings.nav.now },
];

const isActive = (href: string) => {
  if (href === '/' || href === `/${locale}/`) {
    return currentPath === href;
  }
  return currentPath === href || currentPath.startsWith(href);
};

const homeHref = localizePath('/', locale);
const brandLabel = locale === 'es' ? `Inicio — ${'Dylan Yool'}` : `Home — Dylan Yool`;

// Build the per-locale alternates object expected by LanguageToggle.
const other = otherLocale(locale);
const alternates: Record<'en' | 'es', string> = {
  en: localizePath(currentPath, 'en'),
  es: localizePath(currentPath, 'es'),
};
// Override the "other" locale with the page-supplied alternate URL when
// available — this is how a translated blog post points at its counterpart
// instead of a 404.
alternates[other] = alternateUrl ?? alternates[other];
---

<header class="site-header" data-reveal>
  <div class="wrap">
    <a href={homeHref} class="brand" aria-label={brandLabel}>
      <span class="brand-mark" aria-hidden="true">
        <span class="brand-mark-inner">d</span>
      </span>
      <span class="brand-text">
        <span class="brand-name">Dylan</span>
        <span class="brand-meta">Yool</span>
      </span>
    </a>

    <nav aria-label={locale === 'es' ? 'Navegación principal' : 'Primary'}>
      <ul>
        {
          NAV.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class={isActive(item.href) ? 'active' : ''}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="toggle">
          <LanguageToggle alternates={alternates} />
        </li>
        <li class="toggle">
          <ThemeToggle />
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid var(--hairline);
  }

  .wrap {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 0.85rem var(--content-pad);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .wrap {
      padding: 1rem var(--content-pad-lg);
    }
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text);
    padding: 0.25rem 0.35rem 0.25rem 0.1rem;
    border-radius: 8px;
    margin-left: -0.35rem;
    transition:
      color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
    text-decoration: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .brand:hover {
      color: var(--text);
      background: var(--bg-elevated);
      text-decoration: none;
    }
    .brand:active {
      transform: scale(0.97);
    }
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 8px;
    background: var(--text);
    color: var(--text-on-inverse);
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 1.25rem;
    line-height: 1;
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
    transition:
      background var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }

  .brand-mark-inner {
    display: inline-block;
    transform: translateY(-1px);
  }

  @media (hover: hover) and (pointer: fine) {
    .brand:hover .brand-mark {
      background: var(--accent);
      color: var(--text-on-accent);
      transform: rotate(-4deg);
      box-shadow: var(--shadow-glow);
    }
  }

  .brand-text {
    display: inline-flex;
    flex-direction: column;
    line-height: 1.05;
  }

  .brand-name {
    font-weight: 600;
    font-size: 0.98rem;
    letter-spacing: -0.012em;
  }

  .brand-meta {
    font-size: 0.7rem;
    color: var(--text-soft);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  nav ul {
    display: flex;
    align-items: center;
    gap: 0.1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  nav a {
    position: relative;
    color: var(--text-muted);
    font-size: 0.92rem;
    font-weight: 500;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    transition:
      color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
    text-decoration: none;
  }

  @media (hover: hover) and (pointer: fine) {
    nav a:hover {
      color: var(--text);
      background: var(--bg-elevated);
      text-decoration: none;
    }
    nav a:active {
      transform: scale(0.97);
    }
  }

  /* Active state — color + persistent underline + subtle weight. */
  nav a.active {
    color: var(--text);
  }

  nav a.active::after {
    content: '';
    position: absolute;
    left: 0.75rem;
    right: 0.75rem;
    bottom: 0.18rem;
    height: 1.5px;
    background: var(--accent);
    border-radius: 1px;
  }

  nav a.active:hover {
    color: var(--text);
    background: var(--bg-elevated);
  }

  .toggle {
    margin-left: 0.4rem;
  }

  .toggle + .toggle {
    margin-left: 0.35rem;
  }

  @media (max-width: 560px) {
    .wrap {
      flex-wrap: wrap;
      gap: 0.4rem 0.75rem;
      padding: 0.7rem 1rem;
    }
    .brand-meta {
      display: none;
    }
    nav {
      flex: 1 1 100%;
      min-width: 0;
    }
    nav ul {
      flex-wrap: wrap;
      justify-content: flex-end;
      row-gap: 0.25rem;
      width: 100%;
    }
    nav a {
      padding: 0.4rem 0.5rem;
      font-size: 0.86rem;
    }
    nav a.active::after {
      left: 0.5rem;
      right: 0.5rem;
    }
    .toggle {
      margin-left: 0.15rem;
    }
  }
</style>
