---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeBody from '../components/home/HomeBody.astro';
import { SITE } from '../consts';
import { getLocaleFromPath } from '../i18n';

// Both English (/) and Spanish (/es/) homes render the same body, just with
// different locale. The base path detection ensures this file can be placed
// at either route and still derive its locale correctly.
const locale = getLocaleFromPath(Astro.url.pathname);
---

<BaseLayout
  title="Home"
  description={SITE.description}
  canonicalPath={Astro.url.pathname}
  locale={locale}
>
  <HomeBody locale={locale} />
</BaseLayout>
