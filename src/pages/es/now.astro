---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../consts';
import { t, getLocaleFromPath } from '../../i18n';

const locale = getLocaleFromPath(Astro.url.pathname);
const strings = t(locale).now;
const description = strings.description.replace('{name}', SITE.author);
---

<BaseLayout title={strings.title} description={description} locale={locale}>
  <article class="prose" data-reveal>
    <header class="page-header">
      <p class="kicker mono">Ahora</p>
      <h1 class="serif">{strings.h1}</h1>
      <p class="lede" set:html={strings.lede}></p>
      <p class="updated muted mono">
        {strings.lastUpdatedPrefix} <time datetime="2026-06-22">22 de junio de 2026</time>
      </p>
    </header>

    <blockquote class="now-cite">
      <p>{strings.citation.quote}</p>
      <p class="mono muted">
        — <cite
          ><a href="https://nownownow.com/about" rel="noopener"
            >{strings.citation.attribution}</a
          ></cite
        >
      </p>
    </blockquote>

    <h2>{strings.h2a}</h2>
    <ul>
      {strings.learning.map((item) => <li>{item}</li>)}
    </ul>

    <h2>{strings.h2b}</h2>
    <ul>
      {strings.building.map((item) => <li>{item}</li>)}
    </ul>

    <h2>{strings.h2c}</h2>
    <ul>
      {strings.researching.map((item) => <li>{item}</li>)}
    </ul>
  </article>
</BaseLayout>

<style>
  .updated {
    font-size: 0.85rem;
    margin-top: 1rem;
    color: var(--text-soft);
  }

  .now-cite {
    margin: 1.5em 0 2rem;
    font-size: 0.98rem;
  }
  .now-cite p {
    margin: 0;
  }
  .now-cite p + p {
    margin-top: 0.55rem;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }
  .now-cite cite {
    font-style: normal;
  }
</style>
