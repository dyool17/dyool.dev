---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { t, formatDate } from '../../../../i18n';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'es')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return paginate(posts, { pageSize: 20 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const locale = 'es' as const;
const strings = t(locale).blog;

const totalPages: number = page.lastPage;
const currentPage: number = page.currentPage;
const prevUrl: string | undefined = page.url.prev;
const nextUrl: string | undefined = page.url.next;

const allPosts: CollectionEntry<'blog'>[] = (
  await getCollection('blog', ({ data }) => !data.draft && data.lang === locale)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();
const allCategories = [...new Set(allPosts.map((p) => p.data.category))].sort();

const postHref = (id: string) => `/es/blog/${id.replace(/^es\//, '')}/`;
const tagHref = (tag: string) => `/es/blog/tags/${tag}/`;
const categoryHref = (cat: string) =>
  `/es/blog/categories/${cat.toLowerCase().replace(/\s+/g, '-')}/`;

const hasPrev = prevUrl !== undefined;
const hasNext = nextUrl !== undefined;
---

<BaseLayout title={strings.title} description={strings.description} locale={locale}>
  <header class="page-header" data-reveal>
    <p class="kicker mono">Blog</p>
    <h1 class="serif">{strings.h1}</h1>
    <p class="lede" set:html={strings.lede} />
  </header>

  {
    (allTags.length > 0 || allCategories.length > 0) && (
      <div class="discover" data-reveal>
        {allTags.length > 0 && (
          <p class="tag-row" aria-label={strings.tagsLabel}>
            {allTags.map((tag) => (
              <a class="tag tag--link" href={tagHref(tag)}>
                #{tag}
              </a>
            ))}
          </p>
        )}
        {allCategories.length > 0 && (
          <p class="tag-row" aria-label={strings.categoriesLabel}>
            {allCategories.map((cat) => (
              <a class="tag tag--link tag--category" href={categoryHref(cat)}>
                {cat}
              </a>
            ))}
          </p>
        )}
      </div>
    )
  }

  {
    page.data.length === 0 ? (
      <p class="muted">{strings.noPosts}</p>
    ) : (
      <ul class="post-list post-list--flush post-list--with-tags" data-reveal>
        {page.data.map((post) => (
          <li>
            <a class="post-link" href={postHref(post.id)}>
              <span class="post-title">{post.data.title}</span>
              <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate, locale)}
              </time>
              <span class="post-desc">{post.data.description}</span>
              {post.data.tags.length > 0 && (
                <span class="post-tags">
                  {post.data.tags.map((t) => (
                    <a class="tag tag--link" href={tagHref(t)}>
                      #{t}
                    </a>
                  ))}
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>
    )
  }

  {
    (hasPrev || hasNext) && (
      <nav class="pagination" aria-label="Pagination" data-reveal>
        <span class="pagination-spacer">
          {hasPrev && prevUrl && (
            <a href={prevUrl} class="pagination-link">
              <span aria-hidden="true">←</span> {strings.prevPage}
            </a>
          )}
        </span>
        <span class="pagination-info">
          {strings.pageLabel} {currentPage} {strings.ofLabel} {totalPages}
        </span>
        <span class="pagination-spacer pagination-spacer--end">
          {hasNext && nextUrl && (
            <a href={nextUrl} class="pagination-link">
              {strings.nextPage} <span aria-hidden="true">→</span>
            </a>
          )}
        </span>
      </nav>
    )
  }
</BaseLayout>

<style>
  .discover {
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin: 0;
  }

  .tag--link {
    text-decoration: none;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .tag--link:hover {
      color: var(--accent);
      border-color: var(--accent);
      background: var(--accent-soft);
      text-decoration: none;
    }
  }

  .tag--category {
    text-transform: capitalize;
  }

  .pagination {
    margin: 2.5rem 0 1rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    font-size: 0.9rem;
  }

  .pagination-spacer {
    display: flex;
  }

  .pagination-spacer--end {
    justify-content: flex-end;
  }

  .pagination-info {
    color: var(--text-soft);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    text-align: center;
  }

  .pagination-link {
    color: var(--text-muted);
    padding: 0.45rem 0.85rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
    text-decoration: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .pagination-link:hover {
      color: var(--accent);
      border-color: var(--accent);
      background: var(--bg-elevated-2);
      text-decoration: none;
    }
    .pagination-link:active {
      transform: scale(0.97);
    }
  }

  @media (max-width: 560px) {
    .pagination {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .pagination-spacer,
    .pagination-spacer--end {
      justify-content: center;
    }
  }
</style>
