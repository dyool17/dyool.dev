---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { t, formatDate, getLocaleFromPath } from '../../../i18n';

const locale = getLocaleFromPath(Astro.url.pathname);
const strings = t(locale).blog;

const PAGE_SIZE = 20;

const allPosts = (
  await getCollection('blog', ({ data }) => !data.draft && data.lang === locale)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();
const allCategories = [...new Set(allPosts.map((p) => p.data.category))].sort();

const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
const currentPage = 1;
const posts = allPosts.slice(0, PAGE_SIZE);

const hasPrev = false;
const hasNext = totalPages > 1;
const prevUrl: string | null = null;
const nextUrl: string | null = hasNext ? '/es/blog/page/2/' : null;

// ES post ids are namespaced as `es/...`; strip the prefix when building
// the canonical URL, matching the route in src/pages/es/blog/[...slug].astro.
const postHref = (id: string) => `/es/blog/${id.replace(/^es\//, '')}/`;
const tagHref = (tag: string) => `/es/blog/tags/${tag}/`;
const categoryHref = (cat: string) =>
  `/es/blog/categories/${cat.toLowerCase().replace(/\s+/g, '-')}/`;
---

<BaseLayout title={strings.title} description={strings.description} locale={locale}>
  <header class="page-header" data-reveal>
    <p class="kicker mono">Blog</p>
    <h1 class="serif">{strings.h1}</h1>
    <p class="lede" set:html={strings.lede} />
  </header>

  <div class="search-bar" data-reveal>
    <div class="search-input-wrap">
      <span class="search-icon" aria-hidden="true">⌕</span>
      <input
        type="search"
        id="blog-search"
        class="search-input"
        placeholder={strings.searchCta}
        aria-label={strings.searchCta}
      />
      <button
        type="button"
        id="search-clear"
        class="search-clear"
        aria-label="Limpiar búsqueda"
        hidden
      >
        ×
      </button>
    </div>
    <p class="search-status muted" id="search-status" hidden></p>
  </div>

  {
    (allTags.length > 0 || allCategories.length > 0) && (
      <div class="discover" data-reveal>
        {allTags.length > 0 && (
          <p class="tag-row" aria-label={strings.tagsLabel}>
            {allTags.map((tag) => (
              <a class="tag tag--link" href={tagHref(tag)}>
                #{tag}
              </a>
            ))}
          </p>
        )}
        {allCategories.length > 0 && (
          <p class="tag-row" aria-label={strings.categoriesLabel}>
            {allCategories.map((cat) => (
              <a class="tag tag--link tag--category" href={categoryHref(cat)}>
                {cat}
              </a>
            ))}
          </p>
        )}
      </div>
    )
  }

  {
    posts.length === 0 ? (
      <p class="muted">{strings.noPosts}</p>
    ) : (
      <ul class="post-list post-list--flush post-list--with-tags" data-reveal>
        {posts.map((post) => (
          <li>
            <a class="post-link" href={postHref(post.id)}>
              <span class="post-title">{post.data.title}</span>
              <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate, locale)}
              </time>
              <span class="post-desc">{post.data.description}</span>
              {post.data.tags.length > 0 && (
                <span class="post-tags">
                  {post.data.tags.map((t) => (
                    <a class="tag tag--link" href={tagHref(t)}>
                      #{t}
                    </a>
                  ))}
                </span>
              )}
            </a>
          </li>
        ))}
    </ul>
  )
}

{
  (hasPrev || hasNext) && (
    <nav class="pagination" aria-label="Pagination" data-reveal>
      <span class="pagination-spacer">
        {hasPrev && prevUrl && (
          <a href={prevUrl} class="pagination-link">
            <span aria-hidden="true">←</span> {strings.prevPage}
          </a>
        )}
      </span>
      <span class="pagination-info">
        {strings.pageLabel} {currentPage} {strings.ofLabel} {totalPages}
      </span>
      <span class="pagination-spacer pagination-spacer--end">
        {hasNext && nextUrl && (
          <a href={nextUrl} class="pagination-link">
            {strings.nextPage} <span aria-hidden="true">→</span>
          </a>
        )}
      </span>
    </nav>
  )
}
</BaseLayout>

<script>
  (() => {
    const input = document.getElementById('blog-search') as HTMLInputElement | null;
    const clearBtn = document.getElementById('search-clear') as HTMLButtonElement | null;
    const status = document.getElementById('search-status') as HTMLParagraphElement | null;
    const postList = document.querySelector('.post-list') as HTMLUListElement | null;
    if (!input || !clearBtn || !status || !postList) return;

    const items = Array.from(postList.querySelectorAll('li')) as HTMLLIElement[];
    const total = items.length;

    // Store original HTML for each searchable element
    const originals = new Map<Element, string>();
    items.forEach((li) => {
      const title = li.querySelector('.post-title');
      const desc = li.querySelector('.post-desc');
      const tags = li.querySelector('.post-tags');
      if (title) originals.set(title, title.innerHTML);
      if (desc) originals.set(desc, desc.innerHTML);
      if (tags) originals.set(tags, tags.innerHTML);
    });

    const escapeRegex = (s: string) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

    const highlightText = (el: Element, query: string) => {
      const original = originals.get(el);
      if (!original) return;

      if (!query) {
        el.innerHTML = original;
        return;
      }

      // Only highlight text nodes, preserve HTML structure
      const regex = new RegExp(`(${escapeRegex(query)})`, 'gi');
      const temp = document.createElement('div');
      temp.innerHTML = original;

      const walk = (node: Node) => {
        if (node.nodeType === Node.TEXT_NODE) {
          const text = node.textContent || '';
          if (regex.test(text)) {
            const span = document.createElement('span');
            span.innerHTML = text.replace(regex, '<mark>$1</mark>');
            node.replaceWith(span);
          }
        } else {
          Array.from(node.childNodes).forEach(walk);
        }
      };

      walk(temp);
      el.innerHTML = temp.innerHTML;
    };

    const filter = () => {
      const q = input.value.trim().toLowerCase();
      let visible = 0;

      items.forEach((li) => {
        const title = li.querySelector('.post-title');
        const desc = li.querySelector('.post-desc');
        const tags = li.querySelector('.post-tags');

        const titleText = title?.textContent?.toLowerCase() ?? '';
        const descText = desc?.textContent?.toLowerCase() ?? '';
        const tagsText = tags?.textContent?.toLowerCase() ?? '';

        const match = !q || titleText.includes(q) || descText.includes(q) || tagsText.includes(q);
        li.hidden = !match;
        if (match) visible++;

        // Highlight matches
        if (title) highlightText(title, q);
        if (desc) highlightText(desc, q);
        if (tags) highlightText(tags, q);
      });

      clearBtn.hidden = !q;

      if (!q) {
        status.hidden = true;
        status.textContent = '';
      } else if (visible === 0) {
        status.hidden = false;
        status.textContent = 'Ningún post coincide con tu búsqueda.';
      } else if (visible < total) {
        status.hidden = false;
        status.textContent = `Mostrando ${visible} de ${total} posts.`;
      } else {
        status.hidden = true;
        status.textContent = '';
      }
    };

    input.addEventListener('input', filter);
    clearBtn.addEventListener('click', () => {
      input.value = '';
      filter();
      input.focus();
    });
  })();
</script>

<style>
  .search-bar {
    margin: 0 0 2rem;
  }

  .search-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
    max-width: 32rem;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    font-size: 1.2rem;
    color: var(--text-soft);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 0.85rem 3rem 0.85rem 2.8rem;
    font: inherit;
    font-size: 1rem;
    color: var(--text);
    background: var(--bg-elevated);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    transition:
      border-color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
  }

  .search-input::placeholder {
    color: var(--text-soft);
  }

  /* Hide native browser clear button (the × that appears in search inputs) */
  .search-input::-webkit-search-cancel-button,
  .search-input::-webkit-search-decoration {
    -webkit-appearance: none;
    appearance: none;
  }

  .search-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .search-clear {
    position: absolute;
    right: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    font-size: 1.4rem;
    line-height: 1;
    color: var(--text-muted);
    background: transparent;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    transition:
      background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }

  .search-clear:hover {
    background: var(--bg-elevated-2);
    color: var(--text);
  }

  .search-status {
    margin: 0.6rem 0 0;
    font-size: 0.85rem;
  }

  .discover {
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin: 0;
  }

  .tag--link {
    text-decoration: none;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .tag--link:hover {
      color: var(--accent);
      border-color: var(--accent);
      background: var(--accent-soft);
      text-decoration: none;
    }
  }

  .tag--category {
    text-transform: capitalize;
  }

  .pagination {
    margin: 2.5rem 0 1rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    font-size: 0.9rem;
  }

  .pagination-spacer {
    display: flex;
  }

  .pagination-spacer--end {
    justify-content: flex-end;
  }

  .pagination-info {
    color: var(--text-soft);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    text-align: center;
  }

  .pagination-link {
    color: var(--text-muted);
    padding: 0.45rem 0.85rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
    text-decoration: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .pagination-link:hover {
      color: var(--accent);
      border-color: var(--accent);
      background: var(--bg-elevated-2);
      text-decoration: none;
    }
    .pagination-link:active {
      transform: scale(0.97);
    }
  }

  @media (max-width: 560px) {
    .pagination {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .pagination-spacer,
    .pagination-spacer--end {
      justify-content: center;
    }
  }

  /* Search match highlight */
  mark {
    background: #fef08a;
    color: inherit;
    padding: 0.05em 0.2em;
    border-radius: 2px;
  }

  :root.dark mark {
    background: #854d0e;
    color: #fef08a;
  }
</style>
